# syntax=docker/dockerfile:1
# KI-Browser Standalone Docker Image with CEF (Chromium Embedded Framework)
# Uses native CEF bindings for browser automation
#
# Build: docker build -f Dockerfile.cef -t ki-browser:cef .
# Run:   docker run -d --shm-size=2gb -p 9222:9222 ki-browser:cef

# =============================================================================
# Stage 1: Rust Build with CEF (cef-dll-sys downloads CEF automatically)
# =============================================================================
FROM rust:1.87-slim-bookworm AS builder

WORKDIR /build

# Install build dependencies for CEF + FFmpeg (h264) + Tesseract (ocr)
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    cmake \
    build-essential \
    curl \
    bzip2 \
    libgtk-3-dev \
    libglib2.0-dev \
    libnss3-dev \
    libnspr4-dev \
    libatk1.0-dev \
    libatk-bridge2.0-dev \
    libcups2-dev \
    libdrm-dev \
    libgbm-dev \
    libpango1.0-dev \
    libxcomposite-dev \
    libxdamage-dev \
    libxfixes-dev \
    libxrandr-dev \
    libxkbcommon-dev \
    libasound2-dev \
    libdbus-1-dev \
    # FFmpeg dev libs (h264 NVENC feature)
    libavcodec-dev \
    libavformat-dev \
    libavutil-dev \
    libswscale-dev \
    libavfilter-dev \
    libavdevice-dev \
    # Tesseract OCR dev libs (ocr feature)
    libleptonica-dev \
    libtesseract-dev \
    clang \
    && rm -rf /var/lib/apt/lists/*

# Copy Rust project source (inkl. Workspace-Members)
COPY Cargo.toml ./
COPY build.rs ./
COPY src/ ./src/
COPY crates/ ./crates/
# static/ holds the live-viewer HTML embedded via include_str! in the API
COPY static/ ./static/

# Build with ALL features: cef-browser + h264 (NVENC) + ocr (Tesseract)
# The cef-dll-sys crate will download CEF binaries automatically
RUN cargo build --release --no-default-features --features "cef-browser,h264,ocr" 2>&1

# Collect CEF runtime files from build output
RUN mkdir -p /cef && \
    CEF_DIR=$(find /build/target -path "*/cef-dll-sys-*/out/cef_linux_x86_64" -type d | head -1) && \
    echo "CEF found at: $CEF_DIR" && \
    cp -r "$CEF_DIR"/*.so "$CEF_DIR"/*.pak "$CEF_DIR"/*.dat "$CEF_DIR"/*.bin /cef/ && \
    cp "$CEF_DIR"/chrome-sandbox /cef/ && \
    cp -r "$CEF_DIR"/locales /cef/locales

# =============================================================================
# Stage 2: Runtime with CEF + Xvfb + NVIDIA GPU
# =============================================================================
FROM debian:bookworm-slim

LABEL maintainer="KI-Browser Team"
LABEL description="High-performance browser automation with CEF, GPU acceleration and stealth capabilities"
LABEL version="0.2.0"

WORKDIR /app

# Install CEF runtime dependencies + Xvfb for headless display + NVIDIA EGL
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Virtual framebuffer for headless rendering
    xvfb \
    x11-xserver-utils \
    # GTK and X11 libraries (required by CEF)
    libgtk-3-0 \
    libglib2.0-0 \
    libx11-6 \
    libxcomposite1 \
    libxdamage1 \
    libxext6 \
    libxfixes3 \
    libxrandr2 \
    libxrender1 \
    libxkbcommon0 \
    libxi6 \
    libxcursor1 \
    libxss1 \
    libxtst6 \
    # NSS and security libraries
    libnss3 \
    libnspr4 \
    # Audio (ALSA)
    libasound2 \
    # Accessibility
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libatspi2.0-0 \
    # Printing
    libcups2 \
    # Text rendering
    libpango-1.0-0 \
    libcairo2 \
    # DBus
    libdbus-1-3 \
    dbus \
    dbus-x11 \
    # Fonts
    fonts-liberation \
    fonts-dejavu-core \
    fonts-noto-color-emoji \
    # CA certificates for HTTPS
    ca-certificates \
    # FFmpeg runtime libs (h264 NVENC encoding)
    libavcodec59 \
    libavformat59 \
    libavutil57 \
    libswscale6 \
    libavfilter8 \
    libavdevice59 \
    # Tesseract OCR runtime
    tesseract-ocr \
    tesseract-ocr-deu \
    tesseract-ocr-eng \
    libleptonica-dev \
    # Process utilities
    procps \
    curl \
    && rm -rf /var/lib/apt/lists/*

# =============================================================================
# Python + OCR engines (PaddleOCR + Surya) — GPU with automatic CPU fallback
# =============================================================================
# Eigener Layer (selten geaendert -> gutes Caching). paddleocr.rs/surya.rs
# rufen schlicht `python3` aus dem PATH auf (`python3 -c "import paddleocr"`
# bzw. `"import surya"`), daher muessen die Pakete fuer das System-python3
# auffindbar sein. Wir installieren systemweit via --break-system-packages
# (Debian bookworm = PEP668), damit kein PATH-Tweak noetig ist.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-dev \
    python3-venv \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# pip-Installation der OCR-Stacks. PINS SIND VALIDIERT (Container-Tests
# 2026-06-10 auf Unraid RTX2070 / Treiber 570 = max. CUDA 12.8):
#   surya-ocr==0.14.5: LETZTE Version mit In-Process-torch-Inferenz.
#     0.16+/0.20 brauchen einen externen Inference-Server (llama-server bzw.
#     vLLM-im-Docker) — im Container nicht verfuegbar. surya.rs nutzt die
#     0.14-Predictor-API (DetectionPredictor/RecognitionPredictor).
#   transformers==4.53.3: surya 0.14.5 importiert QuantizedCacheConfig,
#     das neuere transformers (>=4.54) entfernt haben.
#   torch ZULETZT mit --force-reinstall als cu128-Pin: surya/paddle ziehen
#     sonst das neueste torch (cu130-Build), dessen CUDA 13 der Treiber 570
#     nicht kann (torch.cuda.is_available()=False). cu128-Wheels sind
#     self-contained (keine CUDA-Toolkit-Installation noetig, nur Host-Treiber).
#     --extra-index-url pypi.org noetig, da der pytorch-Index die transitiven
#     Abhaengigkeiten (typing-extensions etc.) nicht vollstaendig hostet.
#   CPU-FALLBACK bleibt automatisch: ohne CUDA waehlt torch transparent CPU;
#     surya.rs setzt device entsprechend torch.cuda.is_available().
#   paddleocr==2.8.1: paddleocr 3.x braucht paddlepaddle>=3.0, aber PyPIs
#     paddlepaddle-gpu endet bei 2.6.2 (3.x-GPU-Wheels nur ueber den
#     Paddle-eigenen Index). 2.8.1 passt zu paddle 2.6 und zur
#     .ocr(cls=True)-API in paddleocr.rs. GPU-Init scheitert an fehlendem
#     System-cuDNN -> Script faellt automatisch auf CPU zurueck (verifiziert,
#     conf 0.98). Surya nutzt die GPU, Paddle-CPU ist schnell genug.
#   numpy<2: paddleocr 2.x zieht imgaug (unmaintained), das np.sctypes nutzt
#     (in numpy 2.0 entfernt) — Import crasht sonst. paddle 2.6 ist ohnehin
#     gegen numpy 1.x gebaut. torch 2.11 + surya 0.14.5 mit numpy 1.26
#     verifiziert (Container-Test 2026-06-10, beide conf 0.98).
RUN --mount=type=cache,target=/root/.cache/pip \
    pip3 install --break-system-packages \
        "numpy<2" \
        "paddleocr==2.8.1" \
        paddlepaddle-gpu \
        "surya-ocr==0.14.5" \
        "transformers==4.53.3" \
    && pip3 install --break-system-packages --force-reinstall \
        "torch==2.11.0+cu128" torchvision "numpy<2" \
        --index-url https://download.pytorch.org/whl/cu128 \
        --extra-index-url https://pypi.org/simple
# --- CPU-Alternative fuer Paddle (nur falls paddlepaddle-gpu im Build scheitert):
# RUN pip3 install --no-cache-dir --break-system-packages paddlepaddle

# Modell-Pre-Download im Build, damit der erste Request nicht zur Laufzeit
# Modelle uebers Netz ziehen muss (schnelle First-Response, deterministisch).
# Nicht-fatal (|| true): ein fehlgeschlagener Warmup darf den Build NICHT
# killen. device='cpu' beim Surya-Warmup: im Build gibt es keine GPU, der
# Download der Gewichte ist deviceunabhaengig.
RUN python3 -c "from paddleocr import PaddleOCR; PaddleOCR(use_angle_cls=True, lang='en', use_gpu=False, show_log=False)" || true
RUN python3 -c "from surya.detection import DetectionPredictor; from surya.recognition import RecognitionPredictor; DetectionPredictor(device='cpu'); RecognitionPredictor(device='cpu')" || true

# =============================================================================
# GPU graphics libraries (Mesa + glvnd + Vulkan) — SEPARATE post-pip layer.
# Kept AFTER the expensive pip/torch/paddle/surya layer ON PURPOSE: GPU-infra
# iterations (adding a Vulkan/EGL package, tweaking the vendor setup) must NOT
# invalidate the multi-GB OCR pip layer above. Pairs with the pip cache-mount.
# libglvnd0 is the vendor-neutral GL/EGL dispatcher: the NVIDIA container
# runtime mounts libEGL_nvidia.so/libGLX_nvidia.so but NOT a vendor JSON, so
# without glvnd + the NVIDIA vendor config below the dispatcher only ever sees
# Mesa (llvmpipe) and ANGLE's EGL context creation falls back to software.
# =============================================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    libdrm2 \
    libgbm1 \
    libgl1-mesa-glx \
    libgl1-mesa-dri \
    libegl1-mesa \
    libgles2-mesa \
    libglvnd0 \
    libopengl0 \
    libvulkan1 \
    && rm -rf /var/lib/apt/lists/*

# NVIDIA Container Runtime — GPU wird vom Host durchgereicht
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,graphics,utility

# NVIDIA EGL vendor registration (THE GPU-WebGL fix).
# --runtime=nvidia mounts libEGL_nvidia.so.0 / libGLX_nvidia.so.0 +
# libnvidia-eglcore, but it does NOT install a glvnd vendor JSON. Without it the
# libglvnd EGL dispatcher only finds 50_mesa.json -> ANGLE picks Mesa/llvmpipe
# and eglCreateContext on the NVIDIA path fails (EGL_BAD_ATTRIBUTE), so WebGL
# renders in software. Registering the NVIDIA vendor + pinning the dispatcher to
# it makes eglInitialize report VENDOR=NVIDIA (verified live in-container).
RUN mkdir -p /usr/share/glvnd/egl_vendor.d && \
    printf '%s\n' \
      '{' \
      '    "file_format_version" : "1.0.0",' \
      '    "ICD" : {' \
      '        "library_path" : "libEGL_nvidia.so.0"' \
      '    }' \
      '}' > /usr/share/glvnd/egl_vendor.d/10_nvidia.json
# Pin glvnd to the NVIDIA vendor first, then Mesa as fallback.
# NOTE: do NOT set EGL_PLATFORM=surfaceless globally — it makes ANGLE crash on
# init (verified: container SIGSEGV/exit). ANGLE picks its own platform.
ENV __EGL_VENDOR_LIBRARY_FILENAMES=/usr/share/glvnd/egl_vendor.d/10_nvidia.json:/usr/share/glvnd/egl_vendor.d/50_mesa.json

# NOTE: do NOT add a NVIDIA Vulkan ICD here — the NVIDIA container runtime
# already injects /etc/vulkan/icd.d/nvidia_icd.json at runtime. A second ICD in
# /usr/share/vulkan/icd.d causes the RTX 2070 to enumerate twice. Either way,
# ANGLE's Vulkan backend cannot init headless on this NVIDIA driver: it lacks
# VK_EXT_headless_surface, so ANGLE vk_renderer aborts with
# VK_ERROR_INITIALIZATION_FAILED (verified 2026-06-10). Hardware WebGL is not
# achievable in this CEF+NVIDIA+Xvfb setup; gl-egl (software) is the stable path.
# The EGL vendor JSON above is kept (harmless, correct) for any future driver
# that does expose headless rendering.

# Copy CEF runtime libraries
COPY --from=builder /cef/ /opt/cef/

# Copy binary from builder
COPY --from=builder /build/target/release/ki-browser /app/ki-browser

# Live-viewer web UI — served from disk at runtime so it can be updated with a
# `docker cp static/viewer.html ki-browser:/app/static/` + reload, no rebuild.
COPY static/ /app/static/

# Copy entrypoint script
COPY docker-entrypoint-cef.sh /app/docker-entrypoint.sh
RUN chmod +x /app/docker-entrypoint.sh

# Create directories
RUN mkdir -p /app/config /app/profiles /app/data /tmp/cef-data /tmp/.X11-unix

# Set CEF library path — CEF_PATH is used by ki-browser's find_cef_dir()
ENV LD_LIBRARY_PATH=/opt/cef
ENV CEF_PATH=/opt/cef
ENV CEF_RESOURCES_DIR=/opt/cef
ENV CEF_FRAMEWORK_DIR=/opt/cef
ENV CEF_PATH=/opt/cef

# Xvfb display configuration
ENV DISPLAY=:99
ENV XVFB_RESOLUTION=1920x1080x24

# KI-Browser configuration
ENV RUST_LOG=info
ENV KI_BROWSER_API_PORT=9222
ENV KI_BROWSER_API_ENABLED=true
ENV KI_BROWSER_HEADLESS=true
ENV KI_BROWSER_STEALTH=true

# Expose API port
EXPOSE 9222

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:9222/health || exit 1

# Run with entrypoint (starts Xvfb + ki-browser)
ENTRYPOINT ["/app/docker-entrypoint.sh"]
CMD ["--config", "/app/config/config.toml"]
